# EigenCapital — Environment Variables Template
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control (it's in .gitignore).
#
# Required when mt5.enabled: true in config:
#   MT5_ACCOUNT, MT5_PASSWORD, MT5_SERVER

# ── MT5 Bridge ──────────────────────────────────────────────────────
# Required when mt5.enabled: true
# MT5_ACCOUNT=12345678
# MT5_PASSWORD=your_password_here
# MT5_SERVER=Exness-MT5Real

# ── Dashboard Security ──────────────────────────────────────────────
# Optional bearer token for dashboard HTTP API
# EIGENCAPITAL_API_TOKEN=

# ── External APIs ────────────────────────────────────────────────────
# Required for macro narrative governance (weekly LLM-driven overlay)
# OPENCODE_ZEN_API_KEY=sk-...
# Optional: Slack alerts webhook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Engine Configuration ────────────────────────────────────────────
# Engine loop interval in seconds (default: 30)
# EIGENCAPITAL_REFRESH_INTERVAL=30
# Dashboard bind address (default: 127.0.0.1)
# EIGENCAPITAL_BIND=127.0.0.1

# ── MT5 Wine Bridge ─────────────────────────────────────────────────
# WINE_PREFIX=~/.wine_mt5
# MT5_BRIDGE_PORT=9879

# ── Environment Overlay ──────────────────────────────────────────────
# EIGENCAPITAL_ENV=paper

# ── Python Path (Required) ──────────────────────────────────────────
PYTHONPATH=.
