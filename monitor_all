#!/usr/bin/env zsh
# QuantForge Paper Trading Monitor
# Pulls LIVE market data from yfinance. Serves dashboard.
# Usage: ./monitor_all  |  Ctrl+C to stop.

set -e
cd "$(dirname "$0")"

echo "========================================================"
echo "  QuantForge Paper Trading  |  LIVE MARKET FEED"
echo "========================================================"
echo ""

source .venv/bin/activate

# Kill ANY process on port 5000 — including orphaned daemon threads
fuser -k 5000/tcp 2>/dev/null || true
sleep 1
# Verify port is clear
if fuser 5000/tcp >/dev/null 2>&1; then
    fuser -k -9 5000/tcp 2>/dev/null || true
    sleep 1
fi

python paper_trading/monitor.py
